
# Elastic Beanstalk Files
.elasticbeanstalk/*
!.elasticbeanstalk/*.cfg.yml
!.elasticbeanstalk/*.global.yml

# --- Virtual Environments ---
# Exclude the folders where your local libraries are installed
venv/
.venv/
env/
lib/
bin/
include/

# --- Django Specific ---
# Exclude the local database and secret keys
.env
local_settings.py
*.log

# --- Python Build/Cache ---
# Exclude temporary files generated by Python
__pycache__/
*.py[cod]
*$py.class
.python-version


# --- IDEs & OS ---
# Exclude configuration files for PyCharm, VSCode, and Mac/Windows
.idea/
.vscode/
.DS_Store
Thumbs.db